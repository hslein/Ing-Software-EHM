{
  "name": "@org/ehm_back",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": ["{options.outputPath}"],
        "options": {
          "outputPath": "dist/apps/ehm_back",
          "main": "apps/ehm_back/src/main.ts",
          "tsConfig": "apps/ehm_back/tsconfig.app.json",
          "assets": ["apps/ehm_back/src/assets"]
        }
      },
"serve": {
  "executor": "@nx/js:node",
  "options": {
    "buildTarget": "@org/ehm_back:build",
    "watch": true
  }
}
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}